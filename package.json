    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-i18next": "^15.7.0",
    "react-responsive-modal": "^7.1.0",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.1.12",
    "yup": "^1.7.1"
